---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Próximamente — Sagiii.dev">
  <div style="max-width:600px;margin:0 auto;padding:5rem 1.5rem;text-align:center;">
    <div style="font-size:5rem;margin-bottom:1.5rem;">🦊</div>
    <h1 style="font-size:2rem;font-weight:700;margin-bottom:1rem;">
      Próximamente <span style="color:var(--fox)">...</span>
    </h1>
    <p style="color:var(--text-muted);line-height:1.8;margin-bottom:2rem;">
      Este proyecto está en desarrollo. Pronto estará disponible para ver en vivo.
    </p>
    <a href="/projects" class="btn-fox">
      <i class="bi bi-arrow-left"></i> Ver otros proyectos
    </a>
  </div>
</Layout>
